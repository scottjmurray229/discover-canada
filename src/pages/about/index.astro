    font-size: 1.02rem;
    line-height: 2;
    color: var(--color-deep-night);
    font-weight: 300;
  }
  .letter-text strong { font-weight: 600; }
  .letter-text em { font-style: italic; }

  /* ═══════════════════════════════════════════
     TIMELINE
     ═══════════════════════════════════════════ */
  .timeline-section {
    padding: 80px 24px 100px;
    background: var(--color-white);
  }
  .timeline-header {
    text-align: center;
    max-width: var(--content-lg);
    margin: 0 auto 72px;
  }
  .section-eyebrow {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-warm-coral);
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    color: var(--color-deep-night);
    line-height: 1.15;
  }
  .timeline {
    max-width: var(--max-width, 1120px);
    margin: 0 auto;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
    background: linear-gradient(to bottom, #EBE4D8, var(--color-ocean-teal), var(--color-warm-coral), var(--color-warm-gold), #EBE4D8);
  }
  .tl-item {
    display: grid;
    grid-template-columns: 1fr 1fr;
